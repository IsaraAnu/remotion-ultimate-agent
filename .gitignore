# --- Python Specifics ---
# Ignore the virtual environment
mcp-brain/venv/
# Ignore python cache
**/__pycache__/
*.py[cod]
*$py.class

# --- Node.js Specifics ---
# Ignore the heavy node_modules folder
remotion-studio/node_modules/
# Ignore npm/yarn logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Remotion Artifacts ---
# Ignore the rendered mp4 videos (They are too big for Git)
remotion-studio/out/
# Ignore the rendering logs
remotion-studio/render_log.txt

# --- Personal Assets & Sensitive Data ---
# Ignore any environment variables
.env
# Ignore your personal logos/images inside assets but keep the folder
remotion-studio/assets/*
!remotion-studio/assets/.gitkeep

# --- OS Specifics ---
.DS_Store
Thumbs.db